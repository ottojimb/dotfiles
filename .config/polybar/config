[bar/main]
bottom = true
width = 100%
height = 48

background = ${xrdb:color0:#222}
current = ${xrdb:color1:#222}
foreground = ${xrdb:color7:#222}
comment = ${xrdb:color7:#222}
cyan = ${xrdb:color7:#222}
green = ${xrdb:color7:#222}
orange = ${xrdb:color7:#222}
pink = ${xrdb:color7:#222}
purple = ${xrdb:color7:#222}
red = ${xrdb:color7:#222}
yellow = ${xrdb:color7:#222}

line-color = ${self.background}
line-size = 1

spacing = 1
border-left-size = 0
border-right-size = 0
# border-top-size = ${self.line-size}
# border-top-color = ${self.background}
padding = 2
module-margin = 2

font-0 = "pango:style=monospace:size=16;3"
font-1 = "DejaVu Sans:pixelsize=16;2"
font-2 = "Font Awesome 5 Free:style=Solid:pixelsize=16;2"
font-3 = "Font Awesome 5 Brands:style=Regular:pixelsize=16;2"
font-4 = "Material Icons:style=Regular:size=16;5"

tray-position = right
tray-maxsize = 24
modules-left = i3
modules-right = player-mpris-simple filesystem cpu memory wired-network battery0 date

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
wrapping-scroll = false
ws-icon-0 = 0;´å╝
ws-icon-1 = 1;´äá
ws-icon-2 = 2;´üä
ws-icon-3 = 3;´ë®
ws-icon-4 = 4;´çÇ
ws-icon-5 = 5;´ç║
ws-icon-6 = 6;´ÄÆ
ws-icon-7 = 7;7
ws-icon-8 = 8;8
ws-icon-9 = 9;9
label-focused = %icon%
label-focused-padding = 4
label-focused-foreground = ${bar/main.cyan}
label-focused-background = ${bar/main.current}
label-focused-underline= ${bar/main.pink}
label-unfocused = ${self.label-focused}
label-unfocused-padding = ${self.label-focused-padding}
label-unfocused-foreground = ${bar/main.foreground}
label-unfocused-background = ${bar/main.background}
label-unfocused-underline= ${bar/main.background}
label-visible = ${self.label-focused}
label-visible-padding = ${self.label-unfocused-padding}
label-visible-foreground = ${self.label-focused-foreground}
label-visible-background = ${self.label-unfocused-background}
label-visible-underline= ${self.label-unfocused-underline}
label-urgent = ${self.label-focused}
label-urgent-padding = ${self.label-focused-padding}
label-urgent-foreground = ${self.label-unfocused-foreground}
label-urgent-background = ${self.label-focused-background}
label-urgent-underline= ${bar/main.red}

